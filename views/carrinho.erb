<link rel="stylesheet" href="css/carrinho.css">
<script type="module" src="scripts/element_factory.js" defer></script>
<script type="module" src="scripts/carrinho.js" defer></script>
<div class="cart-summary">
  <h2>Carrinho</h2>
  <% if !@itens_carrinho_usuario.nil? and @itens_carrinho_usuario.count > 0 %>
    <% @itens_carrinho_usuario.each do |item| %>
      <div class="cart-item" id="<%= item.produto.id %>">
        <a target="_self" href="/produto?id_usuario=<%= @id_usuario %>&id_produto=<%= item.produto.id %>">
          <%= item.produto.nome %>
        </a>
        <p class="quantidade" id="<%= item.quantidade %>"><strong>Quantidade:</strong> <%= item.quantidade %></p>
        <p>Total: <%= item.produto.preco * item.quantidade %></p>
        <!-- aqui -->
        <button class="remover-button" id="<%= item.id %>">REMOVER</button>
      </div>
    <% end %>
    <button id="comprar-button">Comprar Itens</button>
  <% else %>
    <h3>Você não possui itens no seu carrinho ainda</h3>
  <% end %>
</div>