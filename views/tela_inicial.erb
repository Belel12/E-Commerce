<script src="scripts/search_bar_event_listener.js" defer></script>
<h2>Bem vindo ao E-Commerce</h2>
<% if @produtos.length > 0 %>
  <h3>Confira produtos disponiveis</h3>
  <fieldset>
    <label for="busca">Buscar Produto</label>
    <input id="busca" type="text" placeholder="Digite aqui o nome do produto que deseja buscar">
    <button id="buscar_button" type="button">Buscar</button>
  </fieldset>
  <ul>
    <% @produtos.each do |produto| %>
      <li>
        <p>Nome:
          <a class="produto-inspect"
             target="_self"
             href="/produto?id_usuario=<%= @id_usuario %>&id_produto=<%= produto.id %>">
          <%= produto.nome %>
          </a>
        </p>
        <p>Preço: <%= produto.preco.to_s %> R$</p>
      </li>
    <% end %>
  </ul>
<% else %>
  <h3>Nenhum produto encontrado, mas você pode publicar o seu :)</h3>
<% end %>

